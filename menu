function Tab:AddSlider(config)
    local name     = config.Name or "Slider"
    local min      = config.Min or 0
    local max      = config.Max or 100
    local default  = config.Default or min
    local step     = config.Step or 1
    local suffix   = config.Suffix or ""
    local callback = config.Callback or function() end
    
    local ord = self:NextOrder()
    local row = makeRow(self.Page, 46, ord)
    
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0.6, 0, 0, 20)
    lbl.Position = UDim2.new(0, 12, 0, 3)
    lbl.BackgroundTransparency = 1
    lbl.Text = name
    lbl.TextColor3 = Theme.Text
    lbl.TextSize = 12
    lbl.Font = Enum.Font.Gotham
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = row
    
    local valLbl = Instance.new("TextLabel")
    valLbl.Size = UDim2.new(0, 70, 0, 20)
    valLbl.Position = UDim2.new(1, -80, 0, 3)
    valLbl.BackgroundTransparency = 1
    valLbl.TextColor3 = Theme.TextDim
    valLbl.TextSize = 12
    valLbl.Font = Enum.Font.Gotham
    valLbl.TextXAlignment = Enum.TextXAlignment.Right
    valLbl.Parent = row
    
    local sliderBG = Instance.new("Frame")
    sliderBG.Size = UDim2.new(1, -24, 0, 6)
    sliderBG.Position = UDim2.new(0, 12, 0, 32)
    sliderBG.BackgroundColor3 = Theme.SliderBG
    sliderBG.BorderSizePixel = 0
    sliderBG.Parent = row
    Instance.new("UICorner", sliderBG).CornerRadius = UDim.new(1, 0)
    
    local fill = Instance.new("Frame")
    fill.Size = UDim2.new(0, 0, 1, 0)
    fill.BackgroundColor3 = Theme.SliderFill
    fill.BorderSizePixel = 0
    fill.Parent = sliderBG
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)
    
    local thumb = Instance.new("Frame")
    thumb.Size = UDim2.new(0, 12, 0, 12)
    thumb.Position = UDim2.new(1, -6, 0.5, -6)
    thumb.BackgroundColor3 = Color3.new(1,1,1)
    thumb.BorderSizePixel = 0
    thumb.ZIndex = 2
    thumb.Parent = fill
    Instance.new("UICorner", thumb).CornerRadius = UDim.new(1, 0)
    
    local value = default
    
    local function updateVisual()
        local pct = math.clamp((value - min) / (max - min), 0, 1)
        fill.Size = UDim2.new(pct, 0, 1, 0)
        thumb.Position = UDim2.new(1, -6, 0.5, -6)
        if step >= 1 then
            valLbl.Text = tostring(math.floor(value)) .. suffix
        else
            valLbl.Text = string.format("%.2f", value) .. suffix
        end
    end
    updateVisual()
    
    local sliding = false
    local inputBtn = Instance.new("TextButton")
    inputBtn.Size = UDim2.new(1, 0, 1, 0)
    inputBtn.BackgroundTransparency = 1
    inputBtn.Text = ""
    inputBtn.ZIndex = 3
    inputBtn.Parent = sliderBG
    
    local function doSlide(pos)
        local absX = sliderBG.AbsolutePosition.X
        local absW = sliderBG.AbsoluteSize.X
        local pct = math.clamp((pos.X - absX) / absW, 0, 1)
        local raw = min + (max - min) * pct
        local stepped = math.floor(raw / step + 0.5) * step
        value = math.clamp(stepped, min, max)
        updateVisual()
        callback(value)
    end
    
    inputBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            sliding = true; doSlide(input.Position)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            doSlide(input.Position)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then sliding = false end
    end)
    
    local obj = {}
    function obj:Set(v) value = math.clamp(v, min, max); updateVisual(); callback(value) end
    function obj:Get() return value end
    return obj
end

-------------------------------------------------
-- DROPDOWN
-------------------------------------------------
function Tab:AddDropdown(config)
    local name     = config.Name or "Dropdown"
    local options  = config.Options or {"Option 1", "Option 2"}
    local default  = config.Default or options[1]
    local callback = config.Callback or function() end
    
    local ord = self:NextOrder()
    local row = makeRow(self.Page, 30, ord)
    
