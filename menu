        TweenService:Create(row, TWEEN_FAST, {BackgroundColor3 = Theme.Element}):Play()
    end)
    
    btn.MouseButton1Click:Connect(function()
        value = not value
        update()
        callback(value)
    end)
    
    local obj = {}
    function obj:Set(v) value = v; update(); callback(v) end
    function obj:Get() return value end
    return obj
end

