    btn.AutoButtonColor = false
    btn.LayoutOrder = tab._order
    btn.Parent = self.Sidebar
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 5)
    tab.Button = btn
    
    -- Accent bar
    local accentBar = Instance.new("Frame")
    accentBar.Size = UDim2.new(0, 3, 0.55, 0)
    accentBar.Position = UDim2.new(0, 0, 0.225, 0)
    accentBar.BackgroundColor3 = Theme.Accent
    accentBar.BorderSizePixel = 0
    accentBar.Visible = false
    accentBar.Parent = btn
    Instance.new("UICorner", accentBar).CornerRadius = UDim.new(1, 0)
    tab.AccentBar = accentBar
    
    -- Icon placeholder (small colored dot)
    local iconDot = Instance.new("Frame")
    iconDot.Size = UDim2.new(0, 8, 0, 8)
    iconDot.Position = UDim2.new(0, 14, 0.5, -4)
    iconDot.BackgroundColor3 = Theme.TextDim
    iconDot.BorderSizePixel = 0
    iconDot.Parent = btn
    Instance.new("UICorner", iconDot).CornerRadius = UDim.new(1, 0)
    tab.IconDot = iconDot
    
    -- Label
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, -36, 1, 0)
    lbl.Position = UDim2.new(0, 30, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = tab.Name
    lbl.TextColor3 = Theme.TextDim
    lbl.TextSize = 12
    lbl.Font = Enum.Font.Gotham
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = btn
    tab.Label = lbl
    
    -- Page
    local page = Instance.new("ScrollingFrame")
    page.Name = tab.Name .. "_Page"
    page.Size = UDim2.new(1, 0, 1, 0)
    page.BackgroundTransparency = 1
    page.BorderSizePixel = 0
    page.ScrollBarThickness = 3
    page.ScrollBarImageColor3 = Theme.Accent
    page.CanvasSize = UDim2.new(0, 0, 0, 0)
    page.AutomaticCanvasSize = Enum.AutomaticSize.Y
    page.Visible = false
    page.Parent = self.ContentArea
    tab.Page = page
    
    Instance.new("UIPadding", page).PaddingTop = UDim.new(0, 10)
    Instance.new("UIPadding", page).PaddingLeft = UDim.new(0, 14)

    -- We need separate padding instances
    -- Fix: remove the extra paddings and do it properly
    for _, child in ipairs(page:GetChildren()) do
        if child:IsA("UIPadding") then child:Destroy() end
    end
    local pp = Instance.new("UIPadding")
    pp.PaddingTop = UDim.new(0, 10)
    pp.PaddingBottom = UDim.new(0, 10)
    pp.PaddingLeft = UDim.new(0, 14)
    pp.PaddingRight = UDim.new(0, 14)
    pp.Parent = page
    
    local ll = Instance.new("UIListLayout")
    ll.SortOrder = Enum.SortOrder.LayoutOrder
    ll.Padding = UDim.new(0, 5)
    ll.Parent = page
    
    -- Hover
    btn.MouseEnter:Connect(function()
        if self.ActiveTab ~= tab then
            TweenService:Create(btn, TWEEN_FAST, {BackgroundColor3 = Theme.SideHover}):Play()
        end
    end)
    btn.MouseLeave:Connect(function()
        if self.ActiveTab ~= tab then
            TweenService:Create(btn, TWEEN_FAST, {BackgroundColor3 = Theme.Sidebar}):Play()
        end
    end)
    
    -- Click
    btn.MouseButton1Click:Connect(function()
        self:SwitchTab(tab)
    end)
    
    table.insert(self.Tabs, tab)
    
    -- Auto-select first tab
    if #self.Tabs == 1 then
        self:SwitchTab(tab)
    end
    
    return tab
end

function Library:SwitchTab(tab)
    -- Deactivate old
    if self.ActiveTab then
        local old = self.ActiveTab
        TweenService:Create(old.Button, TWEEN_FAST, {BackgroundColor3 = Theme.Sidebar}):Play()
        old.Label.TextColor3 = Theme.TextDim
        old.IconDot.BackgroundColor3 = Theme.TextDim
        old.AccentBar.Visible = false
        old.Page.Visible = false
    end
    -- Activate new
    self.ActiveTab = tab
    TweenService:Create(tab.Button, TWEEN_FAST, {BackgroundColor3 = Theme.SideActive}):Play()
    tab.Label.TextColor3 = Theme.TextBright
    tab.IconDot.BackgroundColor3 = Theme.Accent
    tab.AccentBar.Visible = true
    tab.Page.Visible = true
end

